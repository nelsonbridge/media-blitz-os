{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/enki-state-snapshot.schema.json",
  "title": "Enki State Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "state_id",
    "subject",
    "domain",
    "content_sha256",
    "observation_ids",
    "relationship_ids",
    "context",
    "temporal_status",
    "metadata"
  ],
  "properties": {
    "state_id": {"type": "string", "minLength": 1},
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject_id", "subject_type"],
      "properties": {
        "subject_id": {"type": "string", "minLength": 1},
        "subject_type": {"type": "string", "minLength": 1}
      }
    },
    "domain": {"type": "string", "minLength": 1},
    "content_sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "observation_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true,
      "default": []
    },
    "relationship_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true,
      "default": []
    },
    "context": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "temporal_status": {"type": "string", "minLength": 1},
    "metadata": {"type": "object", "default": {}}
  },
  "anyOf": [
    {"properties": {"observation_ids": {"minItems": 1}}},
    {"properties": {"relationship_ids": {"minItems": 1}}}
  ]
}
