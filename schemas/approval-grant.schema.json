{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/approval-grant.schema.json",
  "title": "Governed Approval Grant",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "approval_id",
    "decision",
    "execution_context",
    "permitted_actions",
    "subject_id",
    "content_sha256",
    "authorized_by",
    "authority_class",
    "issued_at"
  ],
  "properties": {
    "approval_id": {"type": "string", "minLength": 1},
    "decision": {"type": "string", "enum": ["APPROVED", "DENIED"]},
    "execution_context": {"type": "string", "enum": ["TEST", "PRODUCTION"]},
    "permitted_actions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1,
      "uniqueItems": true
    },
    "subject_id": {"type": "string", "minLength": 1},
    "content_sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "authorized_by": {"type": "string", "minLength": 1},
    "authority_class": {"type": "string", "minLength": 1},
    "issued_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": ["string", "null"], "format": "date-time"},
    "revoked_at": {"type": ["string", "null"], "format": "date-time"},
    "consumption_status": {
      "type": "string",
      "enum": ["AVAILABLE", "RESERVED", "CONSUMED", "REVOKED"],
      "default": "AVAILABLE"
    },
    "reserved_by_transaction_id": {"type": ["string", "null"], "minLength": 1},
    "consumed_by_transaction_id": {"type": ["string", "null"], "minLength": 1},
    "metadata": {"type": "object", "default": {}}
  },
  "allOf": [
    {
      "if": {
        "properties": {"consumption_status": {"const": "RESERVED"}},
        "required": ["consumption_status"]
      },
      "then": {
        "required": ["reserved_by_transaction_id"],
        "properties": {
          "reserved_by_transaction_id": {"type": "string", "minLength": 1},
          "consumed_by_transaction_id": {"type": "null"}
        }
      },
      "else": {
        "properties": {"reserved_by_transaction_id": {"type": "null"}}
      }
    },
    {
      "if": {
        "properties": {"consumption_status": {"const": "CONSUMED"}},
        "required": ["consumption_status"]
      },
      "then": {
        "required": ["consumed_by_transaction_id"],
        "properties": {
          "consumed_by_transaction_id": {"type": "string", "minLength": 1},
          "reserved_by_transaction_id": {"type": "null"}
        }
      },
      "else": {
        "properties": {"consumed_by_transaction_id": {"type": "null"}}
      }
    }
  ]
}
