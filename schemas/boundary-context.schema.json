{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enki.local/schemas/boundary-context.schema.json",
  "title": "Enki Boundary Context",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "namespace_id",
    "tenant_id",
    "subject_id",
    "domain",
    "audience",
    "execution_context"
  ],
  "properties": {
    "namespace_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"},
    "tenant_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"},
    "subject_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"},
    "domain": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"},
    "audience": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"},
    "execution_context": {"const": "TEST"}
  }
}
