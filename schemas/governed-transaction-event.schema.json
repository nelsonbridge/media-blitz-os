{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/governed-transaction-event.schema.json",
  "title": "Governed Transaction Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "transaction_id",
    "operation_id",
    "plan_sha256",
    "stage",
    "occurred_at"
  ],
  "properties": {
    "event_id": {"type": "string", "minLength": 1},
    "transaction_id": {"type": "string", "minLength": 1},
    "operation_id": {"type": "string", "minLength": 1},
    "plan_sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "stage": {
      "type": "string",
      "enum": [
        "PLANNED",
        "APPROVAL_RESERVED",
        "RECOVERY_STARTED",
        "APPROVAL_CONSUMED",
        "EFFECT_APPLIED",
        "RECEIPT_PERSISTED",
        "RESERVATION_RELEASED",
        "COMMITTED",
        "RECOVERED",
        "ROLLED_BACK",
        "RECOVERY_REQUIRED",
        "FAILED"
      ]
    },
    "occurred_at": {"type": "string", "format": "date-time"},
    "payload": {"type": "object", "default": {}}
  }
}
